<Application x:Class="StorageChecker.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:StorageChecker.App">
    <Application.Resources>
        <!-- Palette tema Storage Checker -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1565C0"/>
        <SolidColorBrush x:Key="PositiveBrush" Color="#2E7D32"/>
        <SolidColorBrush x:Key="NegativeBrush" Color="#C62828"/>
        <SolidColorBrush x:Key="NetBrush" Color="#EF6C00"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="White"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#DDDDDD"/>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#F5F6FA"/>

        <Style TargetType="TextBlock" x:Key="Header">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style TargetType="Border" x:Key="Card">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.12"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
