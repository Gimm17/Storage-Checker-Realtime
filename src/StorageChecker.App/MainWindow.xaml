<Window x:Class="StorageChecker.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:scottplot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        Title="Storage Checker Realtime" Height="720" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="Header">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <TabControl Margin="6" x:Name="MainTabs" SelectionChanged="MainTabs_SelectionChanged">
    <TabItem Header="Realtime">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Ringkasan sesi -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Border Style="{StaticResource Card}" Background="#E8F5E9" BorderBrush="#4CAF50">
                <StackPanel>
                    <TextBlock Text="Total Tambah" FontSize="11" Foreground="#2E7D32"/>
                    <TextBlock Text="{Binding TotalAddedText}" FontSize="18" FontWeight="Bold" Foreground="#2E7D32"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Background="#E3F2FD" BorderBrush="#2196F3">
                <StackPanel>
                    <TextBlock Text="Total Hapus" FontSize="11" Foreground="#1565C0"/>
                    <TextBlock Text="{Binding TotalDeletedText}" FontSize="18" FontWeight="Bold" Foreground="#1565C0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Background="#FFF3E0" BorderBrush="#FF9800" Margin="0,0,24,0">
                <StackPanel>
                    <TextBlock Text="Net Change" FontSize="11" Foreground="#EF6C00"/>
                    <TextBlock Text="{Binding NetDeltaText}" FontSize="18" FontWeight="Bold" Foreground="#EF6C00"/>
                </StackPanel>
            </Border>
            <TextBlock Text="Status: " Style="{StaticResource Header}" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Margin="0,0,24,0"/>
        </StackPanel>

        <!-- Toolbar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Open in Explorer" Padding="10,4" Margin="0,0,8,0"
                    Command="{Binding OpenInExplorerCommand}"
                    CommandParameter="{Binding Selected}"/>
            <Button Content="Delete" Padding="10,4"
                    Command="{Binding DeleteCommand}"
                    CommandParameter="{Binding Selected}"/>
            <CheckBox Content="Jalankan saat Windows menyala"
                      IsChecked="{Binding AutoStartEnabled}"
                      VerticalAlignment="Center" Margin="24,0,0,0"/>
            <TextBlock Text="Urutkan:" VerticalAlignment="Center" Margin="24,0,6,0"/>
            <ComboBox ItemsSource="{Binding SortOptions}"
                      SelectedItem="{Binding SelectedSort}"
                      VerticalAlignment="Center" Width="120"/>
        </StackPanel>

        <!-- DataGrid event realtime -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding EventsView}"
                  SelectedItem="{Binding Selected}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  EnableRowVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Waktu" Binding="{Binding Time, StringFormat=HH:mm:ss}" Width="80"/>
                <DataGridTextColumn Header="Drive" Binding="{Binding Drive}" Width="50"/>
                <DataGridTextColumn Header="Nama File" Binding="{Binding FileName}" Width="200"/>
                <DataGridTextColumn Header="Δ Perubahan" Binding="{Binding DeltaTextSigned}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{Binding DeltaBrush}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Ukuran" Binding="{Binding SizeText}" Width="90"/>
                <DataGridTextColumn Header="Kategori" Binding="{Binding CategoryText}" Width="120"/>
                <DataGridTextColumn Header="Keamanan" Binding="{Binding SafetyText}" Width="90"/>
                <DataGridTextColumn Header="Path" Binding="{Binding FullPath}" Width="*"/>
            </DataGrid.Columns>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SafetyText}" Value="BERBAHAYA">
                            <Setter Property="Background" Value="#FFE5E5"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                            <Setter Property="Foreground" Value="Gray"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>
    </Grid>
    </TabItem>

    <TabItem Header="Riwayat" DataContext="{Binding History}">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Tanggal: " Style="{StaticResource Header}" VerticalAlignment="Center"/>
                <DatePicker SelectedDate="{Binding SelectedDate}" Margin="0,0,12,0"/>
                <Button Content="Muat" Padding="10,4" Command="{Binding LoadCommand}" Margin="0,0,24,0"/>
                <TextBlock Text="Total hari itu: " Style="{StaticResource Header}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding GrandTotalText}" Foreground="DarkRed"
                           FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>

            <DataGrid Grid.Row="1" ItemsSource="{Binding Summary}" AutoGenerateColumns="False"
                      IsReadOnly="True" HeadersVisibility="Column" MaxHeight="180" Margin="0,0,0,8">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Drive" Binding="{Binding Drive}" Width="60"/>
                    <DataGridTextColumn Header="Kategori" Binding="{Binding Category}" Width="160"/>
                    <DataGridTextColumn Header="Total Tambah" Binding="{Binding Total}" Width="120"/>
                    <DataGridTextColumn Header="Jumlah File" Binding="{Binding FileCount}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <DataGrid Grid.Row="2" ItemsSource="{Binding TopFiles}" AutoGenerateColumns="False"
                      IsReadOnly="True" HeadersVisibility="Column"
                      EnableRowVirtualization="True" VirtualizingPanel.IsVirtualizing="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Drive" Binding="{Binding Drive}" Width="50"/>
                    <DataGridTextColumn Header="Nama File" Binding="{Binding FileName}" Width="200"/>
                    <DataGridTextColumn Header="Δ Tambah" Binding="{Binding DeltaText}" Width="90"/>
                    <DataGridTextColumn Header="Kategori" Binding="{Binding CategoryText}" Width="120"/>
                    <DataGridTextColumn Header="Path" Binding="{Binding FullPath}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </TabItem>

    <TabItem Header="Dashboard" DataContext="{Binding Dashboard}">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                <Border Style="{StaticResource Card}" Background="#E8F5E9" BorderBrush="#4CAF50">
                    <StackPanel>
                        <TextBlock Text="Total Tambah" FontSize="11" Foreground="#2E7D32"/>
                        <TextBlock Text="{Binding TotalAddedText}" FontSize="20" FontWeight="Bold" Foreground="#2E7D32"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Background="#E3F2FD" BorderBrush="#2196F3">
                    <StackPanel>
                        <TextBlock Text="Total Hapus" FontSize="11" Foreground="#1565C0"/>
                        <TextBlock Text="{Binding TotalDeletedText}" FontSize="20" FontWeight="Bold" Foreground="#1565C0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Background="#FFF3E0" BorderBrush="#FF9800" Margin="0,0,24,0">
                    <StackPanel>
                        <TextBlock Text="Net Change" FontSize="11" Foreground="#EF6C00"/>
                        <TextBlock Text="{Binding NetChangeText}" FontSize="20" FontWeight="Bold" Foreground="#EF6C00"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="Rentang:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding Ranges}"
                          SelectedItem="{Binding SelectedRange}"
                          VerticalAlignment="Center" Width="130" Margin="0,0,12,0"/>
                <Button Content="←" Padding="10,4" Command="{Binding PreviousCommand}" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding StartDate, StringFormat=dd/MM/yyyy}" VerticalAlignment="Center" Margin="4,0"/>
                <TextBlock Text="-" VerticalAlignment="Center" Margin="4,0"/>
                <TextBlock Text="{Binding EndDate, StringFormat=dd/MM/yyyy}" VerticalAlignment="Center" Margin="4,0,8,0"/>
                <Button Content="→" Padding="10,4" Command="{Binding NextCommand}" Margin="0,0,4,0"/>
                <Button Content="Refresh" Padding="10,4" Command="{Binding LoadCommand}"/>
            </StackPanel>

            <!-- Charts -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,10,10">
                    <scottplot:WpfPlot x:Name="DailyChart"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,0,10">
                    <scottplot:WpfPlot x:Name="NetChart"/>
                </Border>
                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource Card}">
                    <scottplot:WpfPlot x:Name="CategoryChart"/>
                </Border>
            </Grid>
        </Grid>
    </TabItem>
    </TabControl>
</Window>
